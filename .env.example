# Plaid
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_PRODUCTS=transactions
PLAID_COUNTRY_CODES=US
PLAID_REDIRECT_URI=

# Moonshot
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.ai/v1
MOONSHOT_CLASSIFY_MODEL=kimi-k2-turbo-preview
MOONSHOT_AGENT_MODEL=kimi-k2.6

# App
DB_PATH=./data/finance.db
ENCRYPTION_KEY=
PORT=8090
TZ=America/Denver
REVIEW_CONFIDENCE_THRESHOLD=0.75
REVIEW_AMOUNT_THRESHOLD=200
SYNC_CRON=0 4 * * *
SYNC_ENABLED=true

# Backups (SQLite VACUUM INTO; runs in-process on a separate cron)
BACKUP_DIR=./data/backups
BACKUP_CRON=30 4 * * *
BACKUP_RETAIN=14
BACKUP_ENABLED=true

# S3 off-host backup (optional; leave S3_BUCKET blank to disable).
# Credentials use the standard AWS chain: AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY,
# AWS_PROFILE, or IAM instance role. AWS_REGION applies if S3_REGION is unset.
S3_BUCKET=
S3_PREFIX=finance-dash/
S3_REGION=
S3_ENDPOINT_URL=                 # only set for non-AWS (R2, MinIO, etc.)
S3_FORCE_PATH_STYLE=false        # set to true for MinIO and similar
S3_RETAIN=90                     # number of S3 snapshots to keep
S3_STORAGE_CLASS=STANDARD        # STANDARD | STANDARD_IA | INTELLIGENT_TIERING | GLACIER_IR
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

# Optional shared-secret bearer token for /api/* (leave blank to disable)
APP_AUTH_TOKEN=
